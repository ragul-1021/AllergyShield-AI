# Database Configuration
DATABASE_URL=postgresql://user:password@localhost/allergyshield

# SMTP Email Configuration (for forgot password feature)
# For Gmail: Generate App Password at https://myaccount.google.com/apppasswords (requires 2FA)
# For other email services, use their SMTP settings
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# For testing without sending real emails, leave SMTP_PASSWORD empty
# The app will still function but won't send emails
